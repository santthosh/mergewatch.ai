# =============================================================================
# MergeWatch Web Dashboard — Environment Variables
# =============================================================================
# For local development: copy this file to .env.local and fill in the values.
# For Amplify hosting: these are set automatically by setup-web-ssm.sh and
# the SAM template (infra/template.yaml).

# NextAuth.js ------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# The canonical URL of your deployment (used by NextAuth for callback URLs).
# Local dev: http://localhost:3000
# Amplify: https://main.<app-id>.amplifyapp.com (set automatically)
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth -----------------------------------------------------------------
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: {NEXTAUTH_URL}/api/auth/callback/github
# NOTE: This is a GitHub OAuth App, NOT the GitHub App used for webhooks.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App -------------------------------------------------------------------
# The public install URL for the MergeWatch GitHub App.
# Users are redirected here from the dashboard to grant repo access.
NEXT_PUBLIC_GITHUB_APP_URL=https://github.com/apps/mergewatch-ai/installations/new

# AWS --------------------------------------------------------------------------
# In Amplify, use APP_REGION (AWS_ prefix is reserved). Locally, AWS_REGION works too.
APP_REGION=us-west-2

# DynamoDB table names ---------------------------------------------------------
# These must match the table names from the SAM template output.
# Format: mergewatch-{table}-{stage} (e.g. mergewatch-installations-prod)
DYNAMODB_TABLE_INSTALLATIONS=mergewatch-installations-prod
DYNAMODB_TABLE_REVIEWS=mergewatch-reviews-prod

# Billing (SaaS only) ----------------------------------------------------------
# Set DEPLOYMENT_MODE=saas to enable billing features in the dashboard.
# BILLING_API_URL is the base URL of the BillingHandler Lambda (from SAM output).
# DEPLOYMENT_MODE=saas
# BILLING_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com/<stage>/billing

# Google Analytics (SaaS only, optional) ---------------------------------------
# When set AND DEPLOYMENT_MODE=saas, GA4 loads on public marketing pages
# (landing, pricing, sign-in, terms, privacy, about). Never loads on
# /dashboard/* or in self-hosted deployments. Format: G-XXXXXXXXXX.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
