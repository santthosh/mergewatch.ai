{
  "name": "mergewatch",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered GitHub PR review tool — runs in your AWS account via Amazon Bedrock",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "deploy": "./scripts/deploy.sh",
    "deploy:dev": "./scripts/deploy.sh dev",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:guided": "./scripts/deploy.sh --guided",
    "setup-ssm": "./scripts/setup-ssm.sh",
    "setup-web": "./scripts/setup-web-ssm.sh",
    "web:dev": "cd packages/dashboard && npm run dev",
    "web:build": "cd packages/dashboard && npm run build",
    "logs:webhook": "sam logs --name mergewatch-webhook-prod --tail --stack-name mergewatch",
    "logs:agent": "sam logs --name mergewatch-review-agent-prod --tail --stack-name mergewatch",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "path-to-regexp@<0.1.13": "0.1.13",
      "fast-xml-parser@<5.7.0": "5.7.0",
      "fast-xml-builder@<1.1.7": "1.1.7",
      "fast-uri@<3.1.2": "3.1.2",
      "picomatch@<4.0.4": "4.0.4",
      "brace-expansion@>=5.0.0 <5.0.5": "5.0.5",
      "lodash@<4.18.0": "4.18.1",
      "esbuild@<0.25.0": "0.25.0",
      "hono@<4.12.18": "4.12.18",
      "ip-address@<10.1.1": "10.1.1",
      "postcss@<8.5.10": "8.5.10",
      "vite": "8.0.13"
    }
  }
}
