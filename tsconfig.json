{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/storage-dynamo" },
    { "path": "packages/llm-bedrock" },
    { "path": "packages/lambda" }
  ],
  "include": [],
  "exclude": ["node_modules", ".aws-sam", "packages"]
}
