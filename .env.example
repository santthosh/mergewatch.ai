# =============================================================================
# MergeWatch Self-Hosted Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Only GITHUB_* and one LLM provider config are required.

# --- GitHub App (required) ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- LLM Provider (pick one) ---
# Options: anthropic, litellm, bedrock, ollama
LLM_PROVIDER=anthropic

# Anthropic (default — recommended)
ANTHROPIC_API_KEY=

# LiteLLM proxy (unlocks 100+ providers)
# LITELLM_BASE_URL=http://litellm:4000
# LITELLM_API_KEY=

# Amazon Bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Ollama (experimental — local/air-gapped)
# OLLAMA_BASE_URL=http://ollama:11434

# --- Optional ---
# LLM_MODEL=                     # Override default model ID
# DASHBOARD_BASE_URL=            # Dashboard URL for review links
# PORT=3000                      # Server port
