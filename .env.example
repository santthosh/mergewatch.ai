# =============================================================================
# MergeWatch Self-Hosted Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Create a GitHub App first: https://github.com/settings/apps/new
#   Permissions: pull_requests (rw), contents (r), checks (rw), issues (rw)
#   Events: pull_request, issue_comment, installation

# ── GitHub App (required) ────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=

# Option A: inline PEM (escape newlines with \n)
GITHUB_PRIVATE_KEY=

# Option B: path to .pem file (easier — just download and point to it)
# GITHUB_PRIVATE_KEY_FILE=./github-app.pem

# ── GitHub OAuth (required for dashboard) ────────────────────────────────────
# Found under: GitHub App Settings → OAuth Credentials (same App, not a separate OAuth App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Dashboard Auth (required for dashboard) ──────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Override for production (default: http://localhost:3001)
# DASHBOARD_URL=https://dashboard.your-domain.com

# ── LLM Provider (pick one) ─────────────────────────────────────────────────
# Options: anthropic (default) | litellm | ollama | bedrock
LLM_PROVIDER=anthropic

# Anthropic (default — recommended)
ANTHROPIC_API_KEY=

# LiteLLM proxy (unlocks 100+ providers: OpenAI, Azure, Gemini, Mistral...)
# LITELLM_BASE_URL=http://litellm:4000
# LITELLM_API_KEY=

# Ollama (experimental — local/air-gapped, no API key needed)
# OLLAMA_BASE_URL=http://ollama:11434

# Amazon Bedrock (needs AWS credentials or instance profile)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# LLM_MODEL=                     # Override default model ID for your provider
# GITHUB_APP_SLUG=               # GitHub App slug (for install link in dashboard)
# PORT=3000                      # Server port (default: 3000)
